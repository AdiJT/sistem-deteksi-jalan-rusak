@model Analisis

@{
    ViewData["Title"] = "Detail Analisis";

    var daftarKoordinatSegmen = Model.DaftarSegmen.Where(x => x.Lat is not null && x.Lng is not null).Select((x, i) => new { Id = i + 1, x.Lat, x.Lng }).ToList();
}

<div class="card card-secondary mb-2">
    <div class="card-header">
        <h4>Detail Analisis</h4>
    </div>

    <div class="card-body pt-0">
        <p>Nama : @Model.Nama</p>
        <p>Lokasi : @Model.Lokasi</p>
        <p>Pembuat : @Model.Pembuat</p>
    </div>
</div>

<div class="card mb-2">
    <div class="card-header">
        <h4>Hasil Metode PCI</h4>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class ="table table-striped table-hover" id="table-akun1">
                <thead>
                    <tr>
                        <th>PCI<sub>Avg</sub></th>
                        <th>Kondisi</th>
                        <th>Jenis Penanganan</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@Model.RataRataPCI</td>
                        <td>@Model.Kondisi</td>
                        <td>@Model.JenisPenanganan</td>
                    </tr>
                </tbody>
            </table>
        </div>        
    </div>
</div>

<div class="card mb-2">
    <div class="card-header">
        <h4>Peta Sebaran Segmen</h4>
    </div>

    <div class="card-body">
        @if (daftarKoordinatSegmen.Count > 0)
        {
            <input readonly hidden id="mapData" value="@(Json.Serialize(daftarKoordinatSegmen))"/>
            <div id="map" style="height:400px; width:100%"></div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h4>Daftar Segmen</h4>
    </div>

    <div class="card-body">

        <a class="btn btn-icon icon-left btn-primary mb-3" asp-action="Tambah" asp-controller="Segmen" asp-route-idAnalisis="@Model.Id"><i class="fas fa-plus"></i> Tambah</a>

        <div class="table-responsive">
            <table class="table table-striped table-hover" id="table-akun2">
                <thead>
                    <tr>
                        <th>No.</th>
                        <th>Luas Sampel (m<sup>2</sup>)</th>
                        <th>PCI</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.DaftarSegmen.Count; i++)
                    {
                        var segmen = Model.DaftarSegmen[i];
                        var pciResult = segmen.MetodePCI();
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@segmen.LuasSampel</td>
                            @if (pciResult is not null)
                            {
                                <td>
                                    <table class="table table-bordered">
                                        <thead>
                                            <tr>
                                                <th>Mi</th>
                                                <th>q<sub>Max</sub></th>
                                                <th>TDV<sub>Max</sub></th>
                                                <th>CDV<sub>Max</sub></th>
                                                <th>PCI</th>
                                                <th>Kondisi</th>
                                                <th>Jenis Penanganan</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>@pciResult.MI</td>
                                                <td>@pciResult.QMax</td>
                                                <td>@pciResult.TDVMax</td>
                                                <td>@pciResult.CDVMax</td>
                                                <td>@pciResult.PCI</td>
                                                <td>@pciResult.Kondisi</td>
                                                <td>@pciResult.JenisPenanganan</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </td>
                            }
                            else
                            {
                                <td>Tidak Ada Hasil</td>
                            }
                            <td>
                                <div class="d-flex">
                                    <a asp-controller="Segmen" asp-action="Detail" asp-route-id="@segmen.Id" class="btn btn-icon icon-left btn-warning mr-1"><i class="fas fa-eye"></i></a>
                                    <a asp-controller="Segmen" asp-action="Edit" asp-route-id="@segmen.Id" asp-route-returnUrl="@Context.Request.AbsoluteUri()" class="btn btn-icon icon-left btn-secondary mr-1"><i class="fas fa-pen"></i></a>
                                    <form asp-controller="Segmen" asp-action="Hapus" asp-route-id="@segmen.Id" style="display:inherit">
                                        <button type="submit" class="btn btn-icon icon-left btn-danger"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
 
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script type="text/javascript">
        $(function() {
            const map = L.map('map')
            const dataStr = '@Html.Raw(Json.Serialize(daftarKoordinatSegmen))';
            const data = JSON.parse(dataStr);

            console.log(data);

            map.setView([data[0].lat, data[0].lng], 12);
            data.forEach((x) => {
                console.log(x);
                const marker = L.marker([x.lat, x.lng]).addTo(map);
                marker.bindPopup(`Segmen ${x.id}. Lat : ${x.lat}, Lng : ${x.lng}`);
            });

            L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 15,
                attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);
        });
    </script>
}